# Runtime
NODE_ENV=development
APP_NAME=Campus Angadi
BRAND_MARK=CA
CAMPUS_DISPLAY_NAME=NIT Calicut
WEB_URL=http://localhost:5173
API_URL=http://localhost:3001
API_PORT=3001
LOG_LEVEL=info

# HTTP and observability
GLOBAL_RATE_LIMIT_WINDOW_MS=900000
GLOBAL_RATE_LIMIT_MAX=500
METRICS_ENABLED=true
METRICS_TOKEN=replace-with-a-long-random-production-token
SHUTDOWN_TIMEOUT_MS=15000
CORS_ALLOWED_ORIGINS=http://localhost:5173

# MongoDB must be a replica set for checkout transactions.
MONGODB_URI=mongodb://127.0.0.1:27017/campus_angadi?replicaSet=rs0
MONGODB_AUTO_INDEX=true
MONGODB_MAX_POOL_SIZE=20
MONGODB_MIN_POOL_SIZE=0
MONGODB_SERVER_SELECTION_TIMEOUT_MS=8000

# Redis is optional for local development and required in production.
REDIS_URL=redis://127.0.0.1:6379
OTP_STORE=memory

# Authentication
ALLOWED_EMAIL_DOMAINS=example.edu
ADMIN_EMAILS=
SUPER_ADMIN_EMAILS=
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
OTP_SEND_MAX_PER_HOUR=5
OTP_HASH_SECRET=replace-with-at-least-32-random-characters
JWT_ACCESS_SECRET=replace-with-an-unrelated-32-character-secret
JWT_REFRESH_SECRET=replace-with-another-unrelated-32-char-secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d

# Email. Production requires EMAIL_PROVIDER=smtp and real credentials.
EMAIL_PROVIDER=console
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Campus Angadi
SMTP_FROM_EMAIL=no-reply@example.edu

# Refresh cookie
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=

# Cloudinary
UPLOAD_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=replace-me
CLOUDINARY_API_KEY=replace-me
CLOUDINARY_API_SECRET=replace-me
CLOUDINARY_FOLDER=campusbaza/products
PRODUCT_IMAGE_MAX_BYTES=5000000
PRODUCT_IMAGE_MAX_COUNT=8
CHAT_AUDIO_MAX_BYTES=8000000

# Homepage
HOMEPAGE_FEATURED_LIMIT=8
HOMEPAGE_OFFICIAL_LIMIT=8
HOMEPAGE_SECOND_HAND_LIMIT=8
HOMEPAGE_RECENT_LIMIT=8

# Retention and cleanup
CLEANUP_ENABLED=true
CLEANUP_RUN_ON_START=true
CLEANUP_INTERVAL_MINUTES=60
CLEANUP_LOCK_TTL_SECONDS=600
CLEANUP_BATCH_SIZE=100
TEMP_UPLOAD_RETENTION_HOURS=24
READ_NOTIFICATION_RETENTION_DAYS=180
REVOKED_SESSION_RETENTION_DAYS=30
AUDIT_LOG_RETENTION_DAYS=730

# Vite build-time configuration
VITE_API_URL=/api/v1
VITE_APP_NAME=Campus Angadi
VITE_BRAND_MARK=CA
VITE_CAMPUS_DISPLAY_NAME=NIT Calicut
VITE_WEBRTC_ICE_SERVERS_JSON=[{"urls":"stun:stun.l.google.com:19302"}]
