{
  "name": "@campusbaza/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "vitest run --coverage=false",
    "seed:catalog": "tsx src/scripts/seed-catalog.ts",
    "seed:dealers": "tsx src/scripts/seed-dealers.ts",
    "db:indexes:check": "tsx src/scripts/check-indexes.ts",
    "db:indexes:ensure": "tsx src/scripts/ensure-indexes.ts"
  },
  "dependencies": {
    "@campusbaza/contracts": "file:../../packages/contracts",
    "@campusbaza/validation": "file:../../packages/validation",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "express-rate-limit": "^7.4.1",
    "file-type": "^22.0.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.2",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "socket.io": "^4.8.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/supertest": "^6.0.2",
    "mongodb-memory-server": "^11.2.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
